{
  "name": "openmac",
  "version": "0.7.0",
  "description": "OpenMac OS Agent",
  "main": "dist/index.js",
  "bin": {
    "openmac": "./bin/run.sh"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli.ts",
    "doctor": "ts-node src/cli.ts doctor",
    "onboard": "ts-node src/cli.ts onboard",
    "launchd:install": "ts-node src/cli.ts launchd-install",
    "update:help": "ts-node src/cli.ts update",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit",
    "test": "node --require ts-node/register --test test/**/*.test.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@slack/web-api": "^7.15.0",
    "better-sqlite3": "^11.8.1",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.7",
    "neo-blessed": "^0.2.0",
    "ollama": "^0.5.14",
    "pdf-parse": "^2.4.5",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.16.3",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.5",
    "@types/qrcode-terminal": "^0.12.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
