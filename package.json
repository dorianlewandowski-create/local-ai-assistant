{
  "name": "apex",
  "version": "1.0.0-rc.1",
  "description": "A high-performance, native macOS intelligence layer. Built for speed, secured by kernel-level sandboxing, and driven by Apple Silicon.",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "bin": {
    "apex": "./bin/run.sh"
  },
  "scripts": {
    "build:esbuild": "node build.mjs",
    "build": "tsc -b && node build.mjs",
    "clean": "tsc -b --clean",
    "start": "npm run -s build:esbuild && node dist/cli.bundle.js",
    "doctor": "node dist/cli.bundle.js doctor",
    "onboard": "node dist/cli.bundle.js onboard",
    "launchd:install": "node dist/cli.bundle.js launchd-install",
    "service:status": "node dist/cli.bundle.js service-status",
    "service:safe": "node dist/cli.bundle.js service-safe",
    "service:model": "node dist/cli.bundle.js service-model",
    "service:sandbox": "node dist/cli.bundle.js service-sandbox",
    "service:approvals": "node dist/cli.bundle.js service-approvals",
    "service:approve": "node dist/cli.bundle.js service-approve",
    "service:deny": "node dist/cli.bundle.js service-deny",
    "service:sessions": "node dist/cli.bundle.js service-sessions",
    "update:help": "node dist/cli.bundle.js update",
    "release:pack": "npm run build && PUPPETEER_SKIP_DOWNLOAD=true PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true node dist/cli.bundle.js release-pack",
    "release:verify": "PUPPETEER_SKIP_DOWNLOAD=true PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true node dist/cli.bundle.js release-verify",
    "lint": "oxlint -c .oxlintrc.json",
    "format": "biome format --write --files-ignore-unknown=true --skip-parse-errors src core gateways package.json apex.json tsconfig.json tsconfig.base.json tsconfig.app.json biome.json .oxlintrc.json pnpm-workspace.yaml",
    "format:check": "biome format --files-ignore-unknown=true --skip-parse-errors src core gateways package.json apex.json tsconfig.json tsconfig.base.json tsconfig.app.json biome.json .oxlintrc.json pnpm-workspace.yaml",
    "validate:skill-json": "node scripts/validate-skill-json.mjs",
    "normalize:skill-json": "node scripts/normalize-skill-json.mjs",
    "typecheck": "tsc --noEmit",
    "ci:quick": "npm run format:check && npm run validate:skill-json && npm run lint && npm run typecheck",
    "docs:list-tools": "node scripts/list-tools.mjs",
    "docs:check-tools": "node --import tsx --test --test-force-exit test/docsListToolsGolden.test.ts",
    "test:eval": "node --import tsx --test --test-force-exit test/evals/goldenEval.test.ts",
    "test": "node --import tsx --test --test-force-exit \"test/**/*.test.ts\"",
    "check": "npm run format:check && npm run validate:skill-json && npm run lint && npm run typecheck && npm run build && npm test && npm run test:eval",
    "postinstall": "bash scripts/build-native.sh"
  },
  "dependencies": {
    "@apex/core": "workspace:*",
    "@apex/gateway-discord": "workspace:*",
    "@apex/gateway-slack": "workspace:*",
    "@apex/gateway-telegram": "workspace:*",
    "@apex/gateway-whatsapp": "workspace:*",
    "@apex/macos-node": "workspace:*",
    "@apex/memory": "workspace:*",
    "@apex/types": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.4.0",
    "@slack/web-api": "^7.15.0",
    "better-sqlite3": "^11.8.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "dotenv": "^16.6.1",
    "enquirer": "^2.4.1",
    "ollama": "^0.5.14",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.40.0",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.16.3",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.5",
    "@types/qrcode-terminal": "^0.12.2",
    "esbuild": "^0.25.9",
    "json5": "^2.2.3",
    "oxlint": "^1.59.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
