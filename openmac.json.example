{
  "models": {
    "chat": "gemma4:e4b",
    "chatFallback": "llama3.1:8b",
    "embedding": "nomic-embed-text",
    "embeddingFallback": "mxbai-embed-large",
    "vision": "llama3.2-vision"
  },
  "watcher": {
    "directories": [
      "~/Desktop",
      "~/Downloads"
    ],
    "extensions": [
      ".pdf",
      ".txt",
      ".md",
      ".jpg",
      ".jpeg",
      ".png"
    ]
  },
  "scheduler": {
    "proactiveReviewIntervalMs": 14400000,
    "morningReviewHour": 8
  },
  "storage": {
    "vectorStorePath": "./data/lancedb",
    "sessionStorePath": "./data/sessions.json"
  },
  "sessions": {
    "maxPersistedSessions": 100
  },
  "dashboard": {
    "enabled": false,
    "port": 18788
  },
  "gateways": {
    "telegram": {
      "enabled": false,
      "botToken": "",
      "chatId": ""
    },
    "whatsapp": {
      "enabled": false,
      "executablePath": ""
    }
  },
  "security": {
    "remoteSafeMode": true,
    "remoteAllowedPermissions": [
      "read",
      "write",
      "automation"
    ],
    "authorizationTimeoutMs": 300000,
    "pairingCodeTtlMs": 600000,
    "channelToolAllowlists": {
      "telegram": [],
      "slack": [],
      "whatsapp": []
    }
  }
}
