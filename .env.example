# Use APEX_* variable names only. Non-empty OPENMAC_* keys in the environment will abort startup.
#
# Copy to `.env` and fill in locally. Never commit `.env`.
# Runtime API auth, first-run token, launchd, install root: docs/OPERATOR_TRUST.txt

# ---------------------------------------------------------------------------
# Apex — config path & runtime
# ---------------------------------------------------------------------------
APEX_CONFIG=~/.apex/config.json
# Localhost runtime HTTP API (127.0.0.1). The daemon creates ~/.apex/runtime.token (0600). Clients send Authorization: Bearer <token>.
# Override for CI or manual tools: APEX_RUNTIME_TOKEN=... or APEX_RUNTIME_TOKEN_FILE=/path/to/token
# APEX_RUNTIME_TOKEN=
# APEX_RUNTIME_TOKEN_FILE=
# Optional: override ~/.apex for state (tests). Default: ~/.apex
# APEX_STATE_DIR=
# Repo / release root (contains nodes/macos/...). launchd plist sets APEX_INSTALL_ROOT; set manually if cwd/entrypoint is ambiguous.
# APEX_INSTALL_ROOT=
# Structured trace lines (JSON) to stderr: task/routing/llm_roundtrip/tool_* . Set to 1, true, json, or stderr.
# APEX_TRACE=1
# Provider preference for the runtime router: `local` or `gemini`
APEX_CURRENT_PROVIDER=local
APEX_PROVIDER=
# Router mode: `smart` (default), `always_gemini`, or `always_local`
APEX_ROUTER_MODE=smart
# Privacy mode: boolean (true/false/1/0). When enabled, sensitive prompts stay local.
APEX_PRIVACY_MODE=false
APEX_MODEL_MODE=auto
APEX_LOCKED_MODEL=gemma4:e2b-it-q8_0
APEX_MODEL_PROVIDER=
# Primary Models
APEX_MODEL_REASONING=gemini-3.1-pro
APEX_MODEL_FAST=gemini-3.1-flash
# SDK plugins toggle (boolean)
APEX_SDK_PLUGINS=


# ---------------------------------------------------------------------------
# Apex — models & tiers (Ollama / routing)
# ---------------------------------------------------------------------------
OLLAMA_MODEL=gemma4:e2b-it-q8_0
OLLAMA_FALLBACK_MODEL=llama3.2:3b
OLLAMA_HOST=http://127.0.0.1:11434
# Ollama HTTP budget for /api/chat, generate, embed (ms). Default 120000. Raise if large models time out on first token.
# APEX_OLLAMA_GENERATION_TIMEOUT_MS=120000
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5
OLLAMA_FALLBACK_EMBEDDING_MODEL=
OLLAMA_VISION_MODEL=gemma4:e4b-it-q4_K_M
OLLAMA_TRANSCRIPTION_MODEL=parakeet-tdt
APEX_MODEL_FAST=gemma4:e2b-it-q8_0
APEX_MODEL_REASONING=gemma4:e2b-it-bf16
APEX_MODEL_VISION=gemma4:e4b-it-q4_K_M
APEX_MODEL_CODING=qwen3-coder-next:4b
# ---------------------------------------------------------------------------
# Apex — watcher & scheduler
# ---------------------------------------------------------------------------
APEX_WATCH_DIRECTORIES=~/Downloads,~/Desktop/Apex-Projects
APEX_WATCH_EXTENSIONS=.pdf,.ts,.txt,.png
APEX_PROACTIVE_REVIEW_INTERVAL_MS=3600000
APEX_MORNING_REVIEW_HOUR=8
# Daily digest (read-biased briefing). Optional Telegram delivery uses TELEGRAM_* below.
APEX_DAILY_DIGEST_ENABLED=false
APEX_DAILY_DIGEST_HOUR=8
APEX_DAILY_DIGEST_TELEGRAM=false


# ---------------------------------------------------------------------------
# Apex — security & pairing
# ---------------------------------------------------------------------------
APEX_REMOTE_SAFE_MODE=true
# Allowed remote permission classes
APEX_REMOTE_ALLOWED_PERMISSIONS=read,write,automation
APEX_AUTHORIZATION_TIMEOUT_MS=60000
APEX_PAIRING_CODE_TTL_MS=300000
APEX_PAIRING_STORE_PATH=~/.apex/pairing.json
APEX_CHANNEL_PAIRING_STORE_PATH=~/.apex/channels.json
# Per-gateway tool allowlists (comma-separated). Each name must match the tool
# registry exactly: native tools use bare ids (web_search); SDK plugins use
# PluginId.toolName (e.g. ScreenControl.get_ui_tree); MCP tools use mcp_*__*
# (see docs/TOOL_REGISTRY_NAMING.txt and src/plugins/mcpBridge.ts).
# Examples below use real tool names; tighten or expand for your deployment.
APEX_TELEGRAM_ALLOWED_TOOLS=web_search,recall_facts,get_current_weather
APEX_SLACK_ALLOWED_TOOLS=web_search,calendar_list_events,get_today_schedule
APEX_WHATSAPP_ALLOWED_TOOLS=get_current_time,send_system_notification
APEX_DISCORD_ALLOWED_TOOLS=
APEX_REMOTE_SANDBOX_MODE=true
APEX_REMOTE_SANDBOX_ALLOWED_PERMISSIONS=fs_read,http_get

# ---------------------------------------------------------------------------
# Apex — media, plugins, services, performance
# ---------------------------------------------------------------------------
APEX_MAX_TELEGRAM_FILE_BYTES=20971520
APEX_MAX_VOICE_NOTE_BYTES=5242880
APEX_PLUGINS_ENABLED=true
APEX_PLUGINS_DIRECTORY=./dist/plugins
APEX_RUNTIME_SERVICE_ENABLED=true
APEX_RUNTIME_SERVICE_PORT=18787
APEX_VISION_MIN_CAPTURE_INTERVAL_MS=500

# ---------------------------------------------------------------------------
# Storage & sessions
# ---------------------------------------------------------------------------
VECTOR_STORE_PATH=~/.apex/vector_store
SESSION_STORE_PATH=~/.apex/sessions
APEX_MAX_PERSISTED_SESSIONS=100

# ---------------------------------------------------------------------------
# Gateways
# ---------------------------------------------------------------------------
TELEGRAM_ENABLED=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_ENABLED=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
APEX_SLACK_ALLOW_FROM=
WHATSAPP_ENABLED=
PUPPETEER_EXECUTABLE_PATH=
APEX_WHATSAPP_ALLOW_FROM=
APEX_WHATSAPP_GROUP_POLICY=
APEX_WHATSAPP_GROUP_ALLOW_FROM=
# Discord bot (DM only). Enable after creating an application + bot at https://discord.com/developers/applications
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
APEX_DISCORD_ALLOW_FROM=

# ---------------------------------------------------------------------------
# Models — cloud API keys (GOOGLE_GEMINI_API_KEY preferred; GEMINI_API_KEY alias)
# ---------------------------------------------------------------------------
GOOGLE_GEMINI_API_KEY=
GEMINI_API_KEY=
# Model used by ACP streaming path when APEX_MODEL_PROVIDER=gemini
GOOGLE_GEMINI_MODEL=gemini-3.1-pro

# ---------------------------------------------------------------------------
# Integrations & search APIs
# ---------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
JINA_API_KEY=
PERPLEXITY_API_KEY=
PERPLEXITY_WEB_SEARCH_MODEL=
TAVILY_API_KEY=
WOLFRAM_API_ID=
ARXIV_MAX_RESULTS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional — MCP (config/mcpServers.json placeholders like {{GITHUB_PERSONAL_ACCESS_TOKEN}})
# ---------------------------------------------------------------------------
GITHUB_PERSONAL_ACCESS_TOKEN=
POSTGRES_URL=
BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# Optional — CLI, HTTP deadlines, Ollama circuit breaker, tracing
# ---------------------------------------------------------------------------
# CLI → daemon (defaults are tuned in code; set only to override)
# APEX_CLI_PROMPT_HTTP_TIMEOUT_MS=
# APEX_CLI_CONTROL_HTTP_TIMEOUT_MS=
# APEX_CLI_READ_HTTP_TIMEOUT_MS=
# APEX_CLI_PROMPT_DEADLINE_MS=
# APEX_CLI_OVERLAY_DEADLINE_MS=
# Generic tool / integration HTTP (web search, weather, Spotify, etc.)
# APEX_TOOL_HTTP_TIMEOUT_MS=
# APEX_GEMINI_REST_HTTP_TIMEOUT_MS=
# APEX_DOCTOR_HTTP_TIMEOUT_MS=
# APEX_STARTUP_OLLAMA_TAGS_TIMEOUT_MS=
# Ollama circuit breaker (local inference — failures in rolling window → open)
# APEX_OLLAMA_CB_WINDOW_MS=
# APEX_OLLAMA_CB_FAILURES=
# APEX_OLLAMA_CB_OPEN_MS=
# Debug ingest + JSONL (CLI/daemon hot paths: Router, /api/prompt, etc.). Off unless set.
# APEX_DEBUG=1
# APEX_DEBUG_INGEST_URL=
# APEX_DEBUG_INGEST_TIMEOUT_MS=
# APEX_DEBUG_LOG_FILE=

# ---------------------------------------------------------------------------
# Optional — debug
# ---------------------------------------------------------------------------
APEX_DEBUG_PRUNER=true
DEBUG_PRUNER=goal-aware
