mailpick() {
  if [ "$#" -lt 1 ]; then
    echo 'Usage: mailpick "query" [limit]'
    return 1
  fi
  local results chosen
  results=$(mailsearch "$1" "${2:-10}") || return 1
  chosen=$(_pa_choose_match "$results")
  [ -z "$chosen" ] && { echo 'Cancelled.'; return 1; }
  echo "$chosen"
}

mailread() {
  if [ "$#" -lt 1 ]; then
    echo 'Usage: mailread "query" [limit]'
    return 1
  fi
  local query="$1"
  local limit="${2:-10}"
  local chosen subject sender
  chosen=$(mailpick "$query" "$limit") || return 1
  subject=$(_pa_extract_mail_subject "$chosen")
  sender=$(_pa_extract_mail_sender "$chosen")
  osascript <<OSA
tell application "Mail"
  set subj to "${subject}"
  set sndr to "${sender}"
  repeat with mb in (every mailbox of inbox)
    repeat with m in (every message of mb)
      if (subject of m is subj) and (sender of m is sndr) then
        return ((subject of m) & " | " & (sender of m) & linefeed & (content of m))
      end if
    end repeat
  end repeat
  return "No matching mail body found."
end tell
OSA
}

