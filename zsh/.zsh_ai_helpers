# AI assistant helper commands

aichat() {
  local has_explicit_agent=0
  for arg in "$@"; do
    case "$arg" in
      -a|--agent|--role|--rag|-r)
        has_explicit_agent=1
        break
        ;;
    esac
  done
  if [ "$has_explicit_agent" -eq 1 ]; then
    command aichat "$@"
  else
    command aichat --role personal-assistant "$@"
  fi
}

