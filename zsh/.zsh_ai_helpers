assistant-healthcheck() {
  python3 - <<'PY'
from pathlib import Path
import subprocess

checks = []

def run(cmd):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True)

def add(name, ok, detail):
    checks.append((name, ok, detail.strip()))

for binary in ["ollama", "aichat", "llm", "argc"]:
    proc = run(f"which {binary}")
    add(f"binary:{binary}", proc.returncode == 0, proc.stdout or proc.stderr)

for path in [
    Path.home() / '.zsh_ai_helpers',
    Path.home() / 'Library/Application Support/aichat/config.yaml',
    Path.home() / 'Library/Application Support/aichat/.env',
    Path.home() / 'local-ai-assistant/ai-tools/llm-functions/agents.txt',
]:
    add(f"path:{path.name}", path.exists(), str(path))

for symlink_path in [
    Path.home() / '.zsh_ai_helpers',
    Path.home() / 'local-ai-assistant/ai-tools/llm-functions/agents.txt',
    Path.home() / 'local-ai-assistant/ai-tools/llm-functions/utils/parse_natural_datetime.py',
]:
    add(f"symlink:{symlink_path.name}", symlink_path.is_symlink(), str(symlink_path))

proc = run("ollama list")
models_out = proc.stdout if proc.returncode == 0 else ''
for model in ["llama3.1:8b", "qwen3-vl:4b", "nomic-embed-text"]:
    add(f"model:{model}", model in models_out, model)

proc = run("zsh -ic 'aichat --info'")
add("agent:default", proc.returncode == 0 and "personal-assistant" in proc.stdout, proc.stdout[:200])

notes_root = Path.home() / 'Notes'
for note_path in [
    notes_root / 'inbox.md',
    notes_root / 'ai-research.md',
    notes_root / 'projects',
    notes_root / 'research',
]:
    add(f"notes:{note_path.name}", note_path.exists(), str(note_path))

failed = [item for item in checks if not item[1]]
for name, ok, detail in checks:
    icon = 'OK' if ok else 'FAIL'
    print(f"[{icon}] {name} :: {detail}")

print()
if failed:
    print(f"Healthcheck: {len(failed)} issue(s) found")
else:
    print("Healthcheck: all core checks passed")
PY
}

