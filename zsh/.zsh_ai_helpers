  repeat with f in every folder
    repeat with n in every note of f
      if (name of n contains q) then
        show n
        activate
        return (name of n)
      end if
    end repeat
  end repeat
  return "No matching Apple Note found."
end tell
OSA
}

applenoteappend() {
