_pa_resolve_note_file() {
  python3 - <<'PY' "$1" "$2"
from pathlib import Path
import sys

base = Path(sys.argv[1]).expanduser()
query = sys.argv[2].lower().strip()
slug = query.replace('_', '-').replace(' ', '-')

if not base.exists():
    print('')
    raise SystemExit(0)

exact = base / f"{slug}.md"
if exact.exists():
    print(exact)
    raise SystemExit(0)

candidates = sorted(base.glob('*.md'))
for path in candidates:
    stem = path.stem.lower()
    if slug == stem or slug in stem or any(part and part in stem for part in slug.split('-')):
        print(path)
        raise SystemExit(0)

print('')
PY
}

_pa_append_to_note_section() {
  python3 - <<'PY' "$1" "$2" "$3"
from pathlib import Path
from datetime import datetime
import sys

path = Path(sys.argv[1]).expanduser()
section = sys.argv[2]
text = sys.argv[3]

if not path.exists():
    raise SystemExit(f'Note not found: {path}')

content = path.read_text(encoding='utf-8', errors='ignore')
stamp = datetime.now().strftime('%Y-%m-%d %H:%M')
entry = f'- [{stamp}] {text}'

if section not in content:
    content = content.rstrip() + f'\n\n{section}\n\n' + entry + '\n'
else:
    before, after = content.split(section, 1)
    after = after.rstrip()
    content = before + section + after + '\n' + entry + '\n'

path.write_text(content.rstrip() + '\n', encoding='utf-8')
print(path)
PY
}

