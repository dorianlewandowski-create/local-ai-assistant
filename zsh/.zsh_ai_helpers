      target_file=$(_pa_resolve_note_file "$HOME/Notes/projects" "$target_name")
      ;;
    research)
      target_file=$(_pa_resolve_note_file "$HOME/Notes/research" "$target_name")
      ;;
    *)
      echo 'Use target type: project or research.'
      return 1
      ;;
  esac
  if [ -z "$target_file" ]; then
    echo "No target note found for: $target_name"
    return 1
  fi
  if [ -n "$reason_text" ]; then
    entry="Decision: $decision_text | Reason: $reason_text"
  else
    entry="Decision: $decision_text"
  fi
  _pa_append_to_note_section "$target_file" '## Decisions' "$entry"
  local slug project_id
  slug=$(basename "$target_file" .md)
  project_id=$(_pa_db_project_id "$slug")
  if [ -n "$project_id" ]; then
    sqlite3 "$(_pa_db_path)" "INSERT INTO decisions (project_id, decision, reason, source_type, source_ref, created_at) VALUES ($project_id, '$(_pa_sql_escape "$decision_text")', '$(_pa_sql_escape "$reason_text")', 'helper', '$(_pa_sql_escape "$target_file")', CURRENT_TIMESTAMP);"
    _pa_db_project_upsert_health "$slug"
  fi
}

meetingsummary() {
  if [ "$#" -lt 2 ]; then
    echo 'Usage: meetingsummary "title" <note-file-or-text> [date]'
    return 1
  fi
  local title="$1"
  local source_input="$2"
  local when="${3:-$(date '+%Y-%m-%d %H:%M')}"
  local raw_text file slug prompt summary target_file
  if [ -f "$source_input" ]; then
    raw_text=$(python3 - <<'PY' "$source_input"
from pathlib import Path
import sys
print(Path(sys.argv[1]).read_text(encoding='utf-8', errors='ignore'))
PY
)
  else
    raw_text="$source_input"
  fi
  slug=$(python3 -c 'import re,sys; print(re.sub(r"[^a-z0-9]+", "-", sys.argv[1].lower()).strip("-"))' "$title")
  target_file="$HOME/Notes/meetings/$(date '+%Y-%m-%d')-$slug.md"
  prompt=$(python3 - <<'PY' "$title" "$when" "$raw_text"
import sys
print(f'''Turn these meeting notes into a concise meeting summary.

Title: {sys.argv[1]}
Date: {sys.argv[2]}

Raw notes:
{sys.argv[3]}

Return exactly these sections:
## Summary
- 2-4 bullets

## Decisions
- 1-4 bullets

## Action items
- 1-6 bullets with clear owners if visible

## Open questions
- 0-4 bullets
''')
PY
)
  summary=$(command aichat -m ollama:llama3.1:8b "$prompt") || return 1
  python3 - <<'PY' "$target_file" "$title" "$when" "$summary"
from pathlib import Path
import sys
path = Path(sys.argv[1])
title = sys.argv[2]
when = sys.argv[3]
summary = sys.argv[4].rstrip()
path.parent.mkdir(parents=True, exist_ok=True)
content = f"# {title}\n\nDate: {when}\nTags: #meeting\n\n{summary}\n"
path.write_text(content, encoding='utf-8')
print(path)
PY
  sqlite3 "$(_pa_db_path)" "INSERT INTO meetings (title, meeting_date, note_path, summary, created_at) VALUES ('$(_pa_sql_escape "$title")', '$(_pa_sql_escape "$when")', '$(_pa_sql_escape "$target_file")', '$(_pa_sql_escape "$summary")', CURRENT_TIMESTAMP);"
}

exportproject() {
  if [ "$#" -lt 1 ]; then
    echo 'Usage: exportproject "project name" [file]'
    return 1
  fi
  local query="$1"
  local file="${2:-$HOME/Notes/exports/project-$(_pa_slugify "$query")-$(date '+%Y-%m-%d').md}"
  local project_file project_text inbox reminders events prompt content
  project_file=$(_pa_resolve_note_file "$HOME/Notes/projects" "$query")
  if [ -z "$project_file" ]; then
    echo "No project note found for: $query"
    return 1
  fi
  project_text=$(python3 - <<'PY' "$project_file"
from pathlib import Path
import sys
print(Path(sys.argv[1]).read_text(encoding='utf-8', errors='ignore'))
PY
)
  inbox=$(python3 - <<'PY' "$query"
from pathlib import Path
import sys
path = Path.home() / 'Notes' / 'inbox.md'
if path.exists():
    lines = path.read_text(encoding='utf-8', errors='ignore').splitlines()
    matches = [line for line in lines if sys.argv[1].lower() in line.lower()]
    print('\n'.join(matches[-10:]))
PY
)
  reminders=$(reminderfind "$query")
  events=$(eventfind "$query" 30)
  prompt=$(python3 - <<'PY' "$query" "$project_text" "$inbox" "$reminders" "$events"
import sys
print(f'''Write a concise Markdown project status report for: {sys.argv[1]}

Project note:
{sys.argv[2]}

Matching inbox items:
{sys.argv[3]}

Matching reminders:
{sys.argv[4]}

Matching calendar events:
{sys.argv[5]}

Use sections:
- Status
- Recent Signals
- Risks
- Next Actions
''')
PY
)
  content=$(command aichat -m ollama:llama3.1:8b "$prompt") || return 1
  python3 - <<'PY' "$file" "$content"
from pathlib import Path
import sys
path = Path(sys.argv[1]).expanduser()
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(sys.argv[2].rstrip() + '\n', encoding='utf-8')
print(path)
PY
}
