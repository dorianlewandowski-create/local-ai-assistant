browsercurrent() {
  local front_app="${1:-}"
  if [ -z "$front_app" ]; then
    front_app=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true')
  fi
  case "$front_app" in
    "Safari")
      osascript -e 'tell application "Safari" to try' -e 'return "Safari | " & (name of current tab of front window) & " | " & (URL of current tab of front window)' -e 'on error' -e 'return "No open Safari window found."' -e 'end try'
      ;;
    "Google Chrome Dev")
      osascript -e 'tell application "Google Chrome Dev" to try' -e 'return "Google Chrome Dev | " & (title of active tab of front window) & " | " & (URL of active tab of front window)' -e 'on error' -e 'return "No open Google Chrome Dev window found."' -e 'end try'
      ;;
    "Google Chrome")
      osascript -e 'tell application "Google Chrome" to try' -e 'return "Google Chrome | " & (title of active tab of front window) & " | " & (URL of active tab of front window)' -e 'on error' -e 'return "No open Google Chrome window found."' -e 'end try'
      ;;
    "Arc")
      osascript -e 'tell application "Arc" to try' -e 'return "Arc | " & (title of active tab of front window) & " | " & (URL of active tab of front window)' -e 'on error' -e 'return "No open Arc window found."' -e 'end try'
      ;;
    "Firefox Developer Edition"|"Firefox")
      python3 - <<'PY' "$front_app"
import subprocess
import sys

app = sys.argv[1]
title = subprocess.run([
    'osascript', '-e', f'tell application "{app}" to get name of front window'
], capture_output=True, text=True).stdout.strip() or app

clipboard_before = subprocess.run(['pbpaste'], capture_output=True, text=True).stdout
script = f'''
tell application "{app}" to activate
delay 0.1
tell application "System Events"
  keystroke "l" using command down
  delay 0.1
  keystroke "c" using command down
end tell
delay 0.1
'''
try:
    subprocess.run(['osascript', '-e', script], check=True, capture_output=True, text=True)
    url = subprocess.run(['pbpaste'], capture_output=True, text=True).stdout.strip()
    subprocess.run(['pbcopy'], input=clipboard_before, text=True)
    if url:
        print(f"{app} | {title} | {url}")
    else:
        print(f"No open {app} window found.")
except subprocess.CalledProcessError:
    subprocess.run(['pbcopy'], input=clipboard_before, text=True)
    print(f"Firefox URL capture requires Accessibility permission for System Events.")
PY
      ;;
    *)
      echo 'No supported frontmost browser found.'
      return 1
      ;;
  esac
}

