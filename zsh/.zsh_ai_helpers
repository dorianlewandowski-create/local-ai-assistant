_pa_filter_calendar_noise() {
  python3 - <<'PY'
from datetime import datetime, timedelta
import sys

text = sys.stdin.read().strip()
if not text:
    print('No events found.')
    raise SystemExit(0)

now = datetime.now()
max_date = now + timedelta(days=30)
seen = set()
kept = []

for line in text.splitlines():
    if not line.strip() or line.lower().startswith('no events'):
        continue
    parts = [p.strip() for p in line.split('|')]
    if len(parts) < 4:
        kept.append(line)
        continue
    key = (parts[1].lower(), parts[2], parts[3])
    if key in seen:
        continue
    seen.add(key)
    date_text = parts[2]
    dt = None
    for fmt in ('%A, %d %B %Y at %H:%M:%S', '%Y-%m-%d %H:%M'):
        try:
            dt = datetime.strptime(date_text, fmt)
            break
        except ValueError:
            pass
    if dt is None:
        kept.append(line)
        continue
    if now - timedelta(days=1) <= dt <= max_date:
        kept.append(line)

print('\n'.join(kept) if kept else 'No events found.')
PY
}

