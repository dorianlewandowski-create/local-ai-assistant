inboxtriage() {
  local mode="${1:-preview}"
  python3 - <<'PY' "$mode"
from pathlib import Path
from datetime import datetime
import json
import re
import sqlite3
import subprocess
import sys

mode = sys.argv[1]
inbox = Path.home() / 'Notes' / 'inbox.md'
projects_dir = Path.home() / 'Notes' / 'projects'
research_dir = Path.home() / 'Notes' / 'research'
meetings_dir = Path.home() / 'Notes' / 'meetings'
agents_dir = Path.home() / 'ai-tools' / 'llm-functions' / 'agents' / 'personal-assistant'
parse_script = str(Path.home() / 'ai-tools' / 'llm-functions' / 'utils' / 'parse_natural_datetime.py')

if not inbox.exists():
    raise SystemExit('Inbox not found.')

lines = inbox.read_text(encoding='utf-8', errors='ignore').splitlines()
items = [line for line in lines if line.startswith('- [')]
deduped_items = []
seen_items = set()
for item in items:
    if item in seen_items:
        continue
    seen_items.add(item)
    deduped_items.append(item)
project_slugs = [p.stem for p in sorted(projects_dir.glob('*.md'))] if projects_dir.exists() else []
research_slugs = [p.stem for p in sorted(research_dir.glob('*.md'))] if research_dir.exists() else []

def score_target(text, slug):
    words = [w for w in slug.split('-') if len(w) > 2]
    score = 0
    if slug in text or slug.replace('-', '_') in text:
        score += 3
    score += sum(1 for w in words if w in text)
    return score

def append_section(path, section, item):
    content = path.read_text(encoding='utf-8', errors='ignore') if path.exists() else f'# {path.stem}\n'
    if section not in content:
        content = content.rstrip() + f'\n\n{section}\n\n'
    if item not in content:
        content = content.rstrip() + f'\n{item}\n'
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content.rstrip() + '\n', encoding='utf-8')

def create_reminder(payload):
    due_date = payload.get('due_date', '')
    if due_date:
        due_date = datetime.strptime(due_date, '%Y-%m-%d %H:%M').strftime('%A, %d %B %Y at %H:%M:%S')
    return subprocess.run([
        'osascript',
        str(agents_dir / 'reminders_create_item.applescript'),
        payload.get('title', ''),
        '',
        payload.get('notes', ''),
        due_date,
    ], check=True, capture_output=True, text=True)

def create_calendar_event(payload):
    return subprocess.run([
        'osascript',
        str(agents_dir / 'calendar_create_event.applescript'),
        payload.get('title', ''),
        payload.get('start', ''),
        payload.get('end', ''),
        payload.get('notes', ''),
        '',
    ], check=True, capture_output=True, text=True)

def normalize_item_text(item):
    return re.sub(r'^- \[[^\]]+\]\s*', '', item).strip()

def extract_item_timestamp(item):
    m = re.search(r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2})\]', item)
    return m.group(1) if m else None

def cleanup_title(text):
    value = normalize_item_text(text)
    value = re.sub(r'\b(reminder|todo|follow up|follow-up|calendar|meeting|schedule)\b', '', value, flags=re.I)
    value = re.sub(r'\b(today|tomorrow|tonight|this morning|this afternoon|this evening|next week|in \d+ days|in \d+ weeks)\b', '', value, flags=re.I)
    value = re.sub(r'\b(next|this)\s+(monday|tuesday|wednesday|thursday|friday|saturday|sunday)\b', '', value, flags=re.I)
    value = re.sub(r'\b(at\s+)?\d{1,2}(:\d{2})?\s*(am|pm)\b', '', value, flags=re.I)
    value = re.sub(r'\b\d{4}-\d{2}-\d{2}\s+\d{1,2}:\d{2}\b', '', value)
    value = re.sub(r'\s+', ' ', value).strip(' ,.-')
    return value

def parse_dt(text):
    proc = subprocess.run(['python3', parse_script, text], capture_output=True, text=True)
    if proc.returncode != 0:
        return None
    return proc.stdout.strip()

def infer_time_phrase(text):
    lower = text.lower()
    patterns = [
        r'(in\s+\d+\s+(?:day|days|week|weeks)(?:\s+\d{1,2}(?::\d{2})?\s*(?:am|pm)?)?)',
        r'(this\s+(?:morning|afternoon|evening))',
        r'(tonight)',
        r'(today(?:\s+at)?\s+\d{1,2}(?::\d{2})?\s*(?:am|pm)?)',
        r'(tomorrow(?:\s+at)?\s+\d{1,2}(?::\d{2})?\s*(?:am|pm)?)',
        r'(next\s+week(?:\s+\d{1,2}(?::\d{2})?\s*(?:am|pm)?)?)',
        r'(next\s+(?:monday|tuesday|wednesday|thursday|friday|saturday|sunday)(?:\s+at)?\s+\d{1,2}(?::\d{2})?\s*(?:am|pm)?)',
        r'(this\s+(?:monday|tuesday|wednesday|thursday|friday|saturday|sunday)(?:\s+at)?\s+\d{1,2}(?::\d{2})?\s*(?:am|pm)?)',
        r'((?:today|tomorrow|next\s+(?:monday|tuesday|wednesday|thursday|friday|saturday|sunday)))',
        r'(\d{4}-\d{2}-\d{2}\s+\d{1,2}:\d{2})',
    ]
    for pattern in patterns:
        m = re.search(pattern, lower)
        if m:
            return m.group(1).replace(' at ', ' ')
    return None

def infer_reminder_payload(item):
    text = normalize_item_text(item)
    phrase = infer_time_phrase(text)
    due_date = parse_dt(phrase) if phrase else None
    clean_title = cleanup_title(text)
    return {"title": (clean_title or text)[:120], "notes": text, "due_date": due_date or ''}

def infer_calendar_payload(item):
    text = normalize_item_text(item)
    phrase = infer_time_phrase(text)
    start = parse_dt(phrase) if phrase else None
    if start:
        try:
            start_dt = datetime.strptime(start, '%Y-%m-%d %H:%M')
            end_dt = start_dt.replace(minute=0) if start_dt.minute != 0 else start_dt
            end_dt = end_dt.replace(hour=end_dt.hour + 1 if end_dt.hour < 23 else end_dt.hour)
            end = end_dt.strftime('%Y-%m-%d %H:%M')
        except ValueError:
            end = None
    else:
        end = None
    clean_title = cleanup_title(text)
    return {
        "title": (clean_title or text)[:120],
        "start": start or datetime.now().replace(hour=9, minute=0, second=0, microsecond=0).strftime('%Y-%m-%d %H:%M'),
        "end": end or datetime.now().replace(hour=10, minute=0, second=0, microsecond=0).strftime('%Y-%m-%d %H:%M'),
        "notes": text,
    }

def classify_item(item):
    lower = item.lower()
    suggestion = 'keep in inbox'
    target_path = None
    section = None
    confidence = 0.2
    best_project = None
    best_project_score = 0
    for slug in project_slugs:
        score = score_target(lower, slug)
        if score > best_project_score:
            best_project = slug
            best_project_score = score
    best_research = None
    best_research_score = 0
    for slug in research_slugs:
        score = score_target(lower, slug)
        if score > best_research_score:
            best_research = slug
            best_research_score = score

    if '#meeting' in lower:
        suggestion = 'move to meetings note'
        target_path = meetings_dir / f"{datetime.now().strftime('%Y-%m-%d')}-inbox-triage.md"
        section = '## Inbox triage'
        confidence = 0.95
    elif best_project_score > 0:
        suggestion = f'move to project:{best_project}'
        target_path = projects_dir / f'{best_project}.md'
        section = '## Inbox captures'
        confidence = min(0.95, 0.45 + (best_project_score * 0.12))
    elif best_research_score > 0 or '#research' in lower or '#search' in lower:
        suggestion = f'move to research:{best_research or "search-workflow-study"}'
        target_path = research_dir / f'{best_research or "search-workflow-study"}.md'
        section = '## Captures'
        confidence = min(0.9, 0.5 + (best_research_score * 0.1) + (0.15 if '#search' in lower or '#research' in lower else 0))
    elif any(k in lower for k in ['reminder', 'todo', 'follow up', 'follow-up']):
        suggestion = 'convert to reminder'
        confidence = 0.78
    elif any(k in lower for k in ['calendar', 'meeting', 'schedule', 'tomorrow', 'next week', 'today at', 'tomorrow at']):
        suggestion = 'check for calendar event'
        confidence = 0.72
    return suggestion, target_path, section, confidence

def log_inbox_decision(item, suggestion, confidence, applied, target_type=None, target_ref=None):
    created_at = extract_item_timestamp(item)
    content = normalize_item_text(item)
    tags = ' '.join(re.findall(r'#[a-zA-Z0-9_\-]+', item)) or None
    suggested_type = None
    suggested_ref = None
    if suggestion.startswith('move to project:'):
        suggested_type = 'project'
        suggested_ref = suggestion.split(':', 1)[1]
    elif suggestion.startswith('move to research:'):
        suggested_type = 'research'
        suggested_ref = suggestion.split(':', 1)[1]
    elif suggestion == 'move to meetings note':
        suggested_type = 'meeting'
    elif suggestion == 'convert to reminder':
        suggested_type = 'reminder'
    elif suggestion == 'check for calendar event':
        suggested_type = 'calendar'

    db = Path.home() / 'Notes' / 'assistant.db'
    conn = sqlite3.connect(db)
    conn.execute(
        '''INSERT INTO inbox_items (content, tags, suggested_target_type, suggested_target_ref, confidence, applied, applied_target_type, applied_target_ref, created_at, applied_at)
           VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, CASE WHEN ? = 1 THEN CURRENT_TIMESTAMP ELSE NULL END)''',
        (content, tags, suggested_type, suggested_ref, confidence, 1 if applied else 0, target_type, target_ref, created_at, 1 if applied else 0)
    )
    conn.commit()
    conn.close()

actions = []
kept = []
choice_stream = None
if mode == '--interactive':
    try:
        choice_stream = open('/dev/tty', 'r', encoding='utf-8')
    except OSError:
        choice_stream = sys.stdin

for item in deduped_items[-12:]:
    suggestion, target_path, section, confidence = classify_item(item)

    print(f'{item}\n  -> {suggestion} | confidence={confidence:.2f}')
    if mode == '--apply' and target_path and section:
        append_section(target_path, section, item)
        log_inbox_decision(item, suggestion, confidence, True, section.replace('## ', '').lower().replace(' ', '_'), str(target_path))
        actions.append(item)
    elif mode == '--apply-reminders' and suggestion == 'convert to reminder':
        payload = infer_reminder_payload(item)
        create_reminder(payload)
        log_inbox_decision(item, suggestion, confidence, True, 'reminder', payload.get('title'))
        actions.append(item)
    elif mode == '--apply-calendar' and suggestion == 'check for calendar event':
        payload = infer_calendar_payload(item)
        create_calendar_event(payload)
        log_inbox_decision(item, suggestion, confidence, True, 'calendar', payload.get('title'))
        actions.append(item)
    elif mode == '--interactive':
        print('Apply action? [y]es/[s]kip/[q]uit: ', end='', flush=True)
        choice = choice_stream.readline().strip().lower()
        if choice == 'q':
            break
        if choice == 'y':
            if target_path and section:
                append_section(target_path, section, item)
                log_inbox_decision(item, suggestion, confidence, True, section.replace('## ', '').lower().replace(' ', '_'), str(target_path))
                actions.append(item)
            elif suggestion == 'convert to reminder':
                payload = infer_reminder_payload(item)
                create_reminder(payload)
                log_inbox_decision(item, suggestion, confidence, True, 'reminder', payload.get('title'))
