applenotessearch() {
  if [ "$#" -lt 1 ]; then
    echo 'Usage: applenotessearch "query" [limit]'
    return 1
  fi
  local query="$1"
  local limit="${2:-10}"
  osascript <<OSA
tell application "Notes"
  set q to "${query}"
  set outputLines to {}
  repeat with f in every folder
    set matches to every note of f whose name contains q or body contains q
    set countLimit to (count of matches)
    if countLimit > ${limit} then set countLimit to ${limit}
    repeat with i from 1 to countLimit
      set n to item i of matches
      set previewText to body of n
      if (length of previewText) > 140 then set previewText to text 1 thru 140 of previewText
      set end of outputLines to ((name of f) & " | " & (name of n) & " | " & previewText)
    end repeat
  end repeat
  if (count of outputLines) is 0 then
    return "No matching Apple Notes found."
  end if
  set AppleScript's text item delimiters to linefeed
  set outputText to outputLines as text
  set AppleScript's text item delimiters to ""
  return outputText
end tell
OSA
}

