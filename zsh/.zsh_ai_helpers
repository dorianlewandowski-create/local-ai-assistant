repeatreminder() {
  if [ "$#" -lt 4 ]; then
    echo 'Usage: repeatreminder "Title" "first due" frequency count [notes]'
    echo 'Frequencies: daily, weekly, monthly, weekdays, every:2d, every:2w, every:2m'
    return 1
  fi
  local title="$1"
  local first_due_raw="$2"
  local frequency="$3"
  local count="$4"
  local notes="${5:-}"
  local first_due
  first_due=$(_pa_parse_dt "$first_due_raw") || return 1
  python3 - "$title" "$first_due" "$frequency" "$count" "$notes" <<'PY'
import json, sys
from datetime import datetime, timedelta

title, first_due, frequency, count, notes = sys.argv[1:6]
count = int(count)
dt = datetime.strptime(first_due, "%Y-%m-%d %H:%M")

def add_month(d):
    month = d.month + 1
    year = d.year
    if month > 12:
        month = 1
        year += 1
    day = min(d.day, [31,29 if year % 4 == 0 and (year % 100 != 0 or year % 400 == 0) else 28,31,30,31,30,31,31,30,31,30,31][month-1])
    return d.replace(year=year, month=month, day=day)

items = []
current = dt
for i in range(count):
    items.append({"title": title if count == 1 else f"{title} ({i+1}/{count})", "due_date": current.strftime("%Y-%m-%d %H:%M"), "notes": notes})
    if frequency == "daily":
        current += timedelta(days=1)
    elif frequency == "weekly":
        current += timedelta(days=7)
    elif frequency == "monthly":
        current = add_month(current)
    elif frequency == "weekdays":
        current += timedelta(days=1)
        while current.weekday() >= 5:
            current += timedelta(days=1)
    elif frequency.startswith("every:"):
        interval = frequency.split(":", 1)[1]
        value = int(interval[:-1])
        unit = interval[-1]
        if unit == "d":
            current += timedelta(days=value)
        elif unit == "w":
            current += timedelta(days=7 * value)
        elif unit == "m":
            for _ in range(value):
                current = add_month(current)
        else:
            raise SystemExit("every: interval must end with d, w, or m")
    else:
        raise SystemExit("Frequency must be daily, weekly, monthly, weekdays, or every:Nd/Nw/Nm")
print(json.dumps(items))
PY
}

