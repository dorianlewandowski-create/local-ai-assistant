  local text="$2"
  osascript <<OSA
tell application "Notes"
  set q to "${query}"
  repeat with f in every folder
    repeat with n in every note of f
      if (name of n contains q) then
        set body of n to ((body of n) & "<div><br></div><div>${text}</div>")
        return (name of n)
      end if
    end repeat
  end repeat
  return "No matching Apple Note found."
end tell
OSA
}

