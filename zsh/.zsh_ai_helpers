_pa_db_project_upsert_health() {
  local slug="$1"
  python3 - <<'PY' "$(_pa_db_path)" "$slug"
import sqlite3
import sys

db_path, slug = sys.argv[1:3]
conn = sqlite3.connect(db_path)
row = conn.execute("SELECT id FROM projects WHERE slug = ?", (slug,)).fetchone()
if not row:
    raise SystemExit(0)
project_id = row[0]
next_steps = conn.execute("SELECT count(*) FROM tasks WHERE project_id = ? AND source_type = 'project_next_step'", (project_id,)).fetchone()[0]
decisions = conn.execute("SELECT count(*) FROM decisions WHERE project_id = ?", (project_id,)).fetchone()[0]
updates = conn.execute("SELECT count(*) FROM project_updates WHERE project_id = ?", (project_id,)).fetchone()[0]
score = 50 + min(next_steps, 5) * 6 + min(decisions, 3) * 4 + min(updates, 5) * 2
score = max(0, min(100, score))
if score >= 75:
    label = 'healthy'
elif score >= 50:
    label = 'active'
elif score >= 30:
    label = 'at risk'
else:
    label = 'stalled'
conn.execute("UPDATE projects SET health_score = ?, health_label = ?, updated_at = CURRENT_TIMESTAMP WHERE id = ?", (score, label, project_id))
conn.commit()
conn.close()
PY
}

