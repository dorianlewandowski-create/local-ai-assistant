downloadstriage() {
  local limit="${1:-12}"
  python3 - <<'PY' "$limit"
from pathlib import Path
import sys

limit = int(sys.argv[1])
downloads = Path.home() / 'Downloads'
files = [p for p in downloads.iterdir() if p.is_file()]
files = sorted(files, key=lambda p: p.stat().st_mtime, reverse=True)[:limit]

def classify(path):
    suffix = path.suffix.lower()
    name = path.name.lower()
    if suffix in {'.png', '.jpg', '.jpeg', '.gif', '.webp'}:
        if 'screenshot' in name or 'chatgpt image' in name:
            return 'image -> review or project/research asset'
        return 'image -> archive or project asset'
    if suffix == '.pdf':
        return 'pdf -> research/project document'
    if suffix in {'.dmg', '.pkg'}:
        return 'installer -> app/software asset'
    if suffix in {'.fig', '.sketch'}:
        return 'design file -> project asset'
    if suffix in {'.md', '.txt', '.docx', '.pptx'}:
        return 'document -> review and move into notes/project'
    return 'review manually'

if not files:
    print('No files in Downloads.')
else:
    for p in files:
        print(f'{p.name} | {classify(p)}')
PY
}

