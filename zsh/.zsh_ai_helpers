      tags=$(_pa_auto_tags "$text")
      if [ -n "$tags" ]; then
        text="$text $tags"
      fi
      notessave inbox.md "$text"
      ;;
    project)
      if [ "$#" -lt 2 ]; then
        echo 'Usage: capture project "project name" "text"'
        return 1
      fi
      local project_name="$1"
      shift
      projectcapture "$project_name" "$*"
      ;;
    research)
      if [ "$#" -lt 2 ]; then
        echo 'Usage: capture research "topic" "text"'
        return 1
      fi
      local topic_name="$1"
      shift
      researchcapture "$topic_name" "$*"
      ;;
