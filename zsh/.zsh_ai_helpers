_pa_auto_tags() {
  python3 - <<'PY' "$*"
from pathlib import Path
import re
import sys

text = sys.argv[1].lower()
mapping = {
    '#ai': ['ollama', 'llm', 'model', 'aichat', 'openwebui', 'anythingllm', 'prompt', 'rag'],
    '#productivity': ['calendar', 'schedule', 'reminder', 'todo', 'task', 'workflow'],
    '#search': ['search', 'duckduckgo', 'google', 'web'],
    '#coding': ['code', 'bug', 'debug', 'script', 'python', 'javascript', 'bash', 'repo'],
    '#meeting': ['meeting', 'call', 'sync', 'standup'],
    '#health': ['gym', 'workout', 'doctor', 'run', 'walk'],
}

tags = []
for tag, words in mapping.items():
    if any(word in text for word in words):
        tags.append(tag)

existing = set(re.findall(r'#[a-z0-9_-]+', text))

project_dir = Path.home() / 'Notes' / 'projects'
if project_dir.exists():
    for path in project_dir.glob('*.md'):
        slug = path.stem.lower()
        words = [w for w in slug.split('-') if len(w) > 2]
        if any(word in text for word in words):
            existing_tag = '#' + slug.replace('-', '_')
            if existing_tag not in tags and existing_tag not in existing:
                tags.append(existing_tag)

tag_dir = Path.home() / 'Notes' / 'tags'
if tag_dir.exists():
    for path in tag_dir.glob('*.md'):
        tag_name = '#' + path.stem.lower().replace('-', '_')
        if path.stem.lower() in text and tag_name not in tags and tag_name not in existing:
            tags.append(tag_name)

tags = [tag for tag in tags if tag not in existing]
print(' '.join(tags))
PY
}

